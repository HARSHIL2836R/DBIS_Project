{+      quote_identifier(index_table_name), sql_op);+}

{+  int ret =+}
{+      SPI_execute_with_args(query.data, 1, argtypes, values, nulls, true, 0);+}

{+  if (ret > 0 && SPI_processed > 0) {+}
{+    filenames = NIL;+}
{+    rowgroups_list = NIL;+}

{+    for (uint64 row = 0; row < SPI_processed; row++) {+}
