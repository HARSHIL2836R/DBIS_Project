{+      continue;+}

{+    Var *var = (Var *)left;+}
{+    Const *c = (Const *)right;+}

{+    if (var->varattno != index_attnum)+}
{+      continue;+}

{+    if (c->constisnull)+}
{+      continue;+}

{+    const char *sql_op = get_gsi_operator_sql(op->opno, was_swapped);+}
{+    if (sql_op == NULL)+}
