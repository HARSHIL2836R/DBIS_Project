{+     * only has to handle one shape.+}
{+     */+}
{+    if (IsA(left, Const) && IsA(right, Var)) {+}
{+      Node *tmp = left;+}
{+      left = right;+}
{+      right = tmp;+}
{+      was_swapped = true;+}
{+    }+}

