# Database Credentials
export DB_NAME="postgres"
export DB_USER="postgres"
export DB_PASSWORD="hello"
export DB_HOST="localhost"
export DB_PORT="5432"

# Runtime Config
# Watched parquet roots now come from public.gsi_registry.data_lake_path.
export WATCHER_LOOP_INTERVAL="1.0"
export FILE_STABLE_SECONDS="2.0"
export INDEX_WORKERS="4"
export REGISTRY_REFRESH_SECONDS="60"
export RECONCILE_SECONDS="300"
